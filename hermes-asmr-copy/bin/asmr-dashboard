#!/usr/bin/env python3
"""Local operator dashboard for the ASMR library stack."""
from __future__ import annotations

import argparse
import html
import json
import os
import re
import shutil
import sqlite3
import subprocess
import threading
import time
import urllib.error
import urllib.parse
import urllib.request
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from uuid import uuid4

HOME = Path.home()
STATE_ROOT = Path(os.environ.get("HERMES_ASMR_HOME", str(HOME / ".hermes" / "asmr")))
ASMR_LIBRARY = STATE_ROOT / "bin" / "asmr-library"
ASMR_VIEW = STATE_ROOT / "bin" / "asmr-view"
NEOKIKOERU_SERVE = STATE_ROOT / "bin" / "neokikoeru-serve"
LIBRARY_ROOT = Path(os.environ.get("ASMR_LIBRARY_ROOT", str(Path.home() / "ASMR")))
NEOKIKOERU_DB = HOME / "Library" / "Application Support" / "neokikoeru" / "neokikoeru.db"
NEOKIKOERU_COVERS = HOME / "Library" / "Application Support" / "neokikoeru" / "covers" / "doujin"
ASMRONER_DB = STATE_ROOT / ".asmroner-data" / "asmroner.db"
SUB_EXTS = {".lrc", ".vtt", ".srt", ".ass", ".ssa"}
AUDIO_EXTS = {".mp3", ".wav", ".flac", ".m4a", ".aac", ".ogg", ".opus"}
ASMR_TRACK_API_BASES = ("https://api.asmr.one", "https://api.asmr-200.com", "https://api.asmr-300.com")
RJ_RE = re.compile(r"^RJ\d+$", re.I)

actions: dict[str, dict] = {}
actions_lock = threading.Lock()
track_count_cache: dict[str, tuple[int | None, int]] = {}


def now_ms() -> int:
    return int(time.time() * 1000)


def rj_arg(value: str) -> str:
    rj = (value or "").strip().upper()
    if not RJ_RE.match(rj):
        raise ValueError("RJ must look like RJ01234567")
    return rj


def db_connect() -> sqlite3.Connection | None:
    if not NEOKIKOERU_DB.exists():
        return None
    conn = sqlite3.connect(str(NEOKIKOERU_DB))
    conn.row_factory = sqlite3.Row
    return conn


def http_status(url: str, timeout: float = 3.0) -> dict:
    try:
        with urllib.request.urlopen(url, timeout=timeout) as r:
            body = r.read(256)
            return {"ok": 200 <= r.status < 400, "status": r.status, "body": body.decode("utf-8", "ignore")}
    except Exception as e:
        return {"ok": False, "status": None, "error": str(e)}


def run_capture(argv: list[str], timeout: int = 120) -> dict:
    started = now_ms()
    try:
        p = subprocess.run(
            argv,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=timeout,
            cwd=str(STATE_ROOT),
            env={
                **os.environ,
                "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
            },
        )
        return {
            "argv": argv,
            "exit_code": p.returncode,
            "ok": p.returncode == 0,
            "output": p.stdout[-20000:],
            "started_at": started,
            "finished_at": now_ms(),
        }
    except subprocess.TimeoutExpired as e:
        return {
            "argv": argv,
            "exit_code": 124,
            "ok": False,
            "output": ((e.stdout or "") + (e.stderr or ""))[-20000:],
            "error": f"timed out after {timeout}s",
            "started_at": started,
            "finished_at": now_ms(),
        }
    except Exception as e:
        return {
            "argv": argv,
            "exit_code": 1,
            "ok": False,
            "output": "",
            "error": str(e),
            "started_at": started,
            "finished_at": now_ms(),
        }


def queue_action(name: str, argv: list[str], timeout: int = 600) -> dict:
    action_id = uuid4().hex[:12]
    record = {
        "id": action_id,
        "name": name,
        "argv": argv,
        "status": "running",
        "started_at": now_ms(),
        "finished_at": None,
        "exit_code": None,
        "output": "",
    }
    record["progress"] = action_progress(record)
    with actions_lock:
        actions[action_id] = record

    def worker() -> None:
        result = run_capture(argv, timeout=timeout)
        with actions_lock:
            record.update(result)
            record["status"] = "done" if result["ok"] else "failed"
            record["progress"] = action_progress(record)

    threading.Thread(target=worker, daemon=True).start()
    return record


def _action_rjs(record: dict) -> list[str]:
    seen: list[str] = []
    for arg in record.get("argv") or []:
        if isinstance(arg, str) and RJ_RE.match(arg) and arg.upper() not in seen:
            seen.append(arg.upper())
    return seen


def _relative_db_path(rj: str, db_path: str) -> Path:
    clean = (db_path or "").lstrip("/")
    if clean.upper().startswith(rj.upper() + "/"):
        clean = clean[len(rj) + 1 :]
    return Path(clean)


def _existing_relative_files(root: Path, rj: str) -> set[str]:
    if not root.is_dir():
        return set()
    base = root
    children = [p for p in root.iterdir() if p.is_dir()] if root.exists() else []
    if root.name == f"{rj}.partial" and len(children) == 1:
        base = children[0]
    out: set[str] = set()
    for p in base.rglob("*"):
        if p.is_file() and not p.name.startswith("."):
            try:
                out.add(str(p.relative_to(base)))
            except ValueError:
                out.add(p.name)
    return out


def _expected_audio_count_from_log(rj: str) -> int | None:
    log_path = STATE_ROOT / "logs" / f"{rj}.log"
    if not log_path.exists():
        return None
    try:
        text = log_path.read_text(errors="ignore")[-20000:]
    except OSError:
        return None
    matches = re.findall(r"(?:音轨数|tracks?|audio tracks?)[:：]\s*(\d+)", text, flags=re.I)
    if not matches:
        return None
    try:
        return int(matches[-1])
    except ValueError:
        return None


def _count_audio(paths: set[str]) -> int:
    return sum(1 for p in paths if Path(p).suffix.lower() in AUDIO_EXTS)


def _count_track_leaves(nodes: list[dict]) -> int:
    total = 0
    for node in nodes or []:
        children = node.get("children") if isinstance(node, dict) else None
        if children:
            total += _count_track_leaves(children)
        else:
            total += 1
    return total


def _expected_file_count_from_tracks_api(rj: str) -> int | None:
    cached = track_count_cache.get(rj)
    now = now_ms()
    if cached and now - cached[1] < 30 * 60 * 1000:
        return cached[0]
    try:
        work_number = str(int(rj[2:]))
    except (TypeError, ValueError):
        return None
    for base in ASMR_TRACK_API_BASES:
        url = f"{base}/api/tracks/{work_number}"
        req = urllib.request.Request(
            url,
            headers={"Accept": "application/json", "User-Agent": "Mozilla/5.0"},
        )
        try:
            with urllib.request.urlopen(req, timeout=6) as resp:
                data = json.loads(resp.read().decode("utf-8", "ignore"))
        except (OSError, TimeoutError, json.JSONDecodeError, urllib.error.URLError):
            continue
        if isinstance(data, list):
            count = _count_track_leaves(data)
            if count:
                track_count_cache[rj] = (count, now)
                return count
    track_count_cache[rj] = (None, now)
    return None


def _work_progress(rj: str, status: str = "running") -> dict:
    info = work_info(rj)
    expected_files = [
        f for f in info.get("db_files", [])
        if not f.get("is_folder") and f.get("path")
    ]
    expected_rel = {str(_relative_db_path(rj, f["path"])) for f in expected_files}

    final_root = LIBRARY_ROOT / rj
    stage_root = LIBRARY_ROOT.parent / "AMSR.incoming" / f"{rj}.partial"
    final_files = _existing_relative_files(final_root, rj)
    stage_files = _existing_relative_files(stage_root, rj)
    existing_rel = final_files | stage_files

    if info.get("folder_exists") and existing_rel:
        missing = []
        downloaded = len(existing_rel)
        total = len(existing_rel)
        expected_source = "work-files"
        count_unit = "files"
        missing_count = 0
    elif expected_rel:
        missing = sorted(expected_rel - existing_rel)
        downloaded = len(expected_rel) - len(missing)
        total = len(expected_rel)
        expected_source = "db"
        count_unit = "files"
        missing_count = len(missing)
    else:
        expected_track_files = _expected_file_count_from_tracks_api(rj)
        if expected_track_files:
            missing = []
            downloaded = min(len(existing_rel), expected_track_files)
            total = expected_track_files
            expected_source = "tracks-api"
            count_unit = "files"
            missing_count = max(total - downloaded, 0)
        elif existing_rel:
            missing = []
            downloaded = len(existing_rel)
            total = len(existing_rel)
            expected_source = "staging-files" if stage_files else "work-files"
            count_unit = "files"
            missing_count = 0
        else:
            expected_audio = _expected_audio_count_from_log(rj)
            missing = []
            if expected_audio:
                downloaded = min(_count_audio(existing_rel), expected_audio)
                total = expected_audio
                expected_source = "log-audio"
                count_unit = "audio tracks"
                missing_count = max(total - downloaded, 0)
            else:
                downloaded = len(existing_rel)
                total = None
                expected_source = "unknown"
                count_unit = "files"
                missing_count = None

    if info.get("folder_exists") and existing_rel:
        percent = 100
    elif total:
        percent = round(downloaded * 100 / total)
        if status == "running" and percent >= 100:
            percent = 99
    elif status == "done" and info.get("folder_exists"):
        percent = 100
    else:
        percent = None
    return {
        "rj": rj,
        "title": (info.get("db_work") or {}).get("name") or "",
        "folder_exists": info.get("folder_exists", False),
        "db_work": bool(info.get("db_work")),
        "downloaded_files": downloaded,
        "expected_files": total,
        "expected_source": expected_source,
        "count_unit": count_unit,
        "missing_files": missing[:200],
        "missing_file_count": missing_count,
        "audio_files": info.get("audio_files", 0),
        "subtitle_files": info.get("subtitle_files", 0),
        "stage_files": len(stage_files),
        "final_files": len(final_files),
        "percent": percent,
    }


def action_progress(record: dict) -> dict:
    rjs = _action_rjs(record)
    status = record.get("status") or "running"
    works = [_work_progress(rj, status=status) for rj in rjs]
    if works:
        known_totals = [w["expected_files"] for w in works if w.get("expected_files") is not None]
        total = sum(known_totals) if len(known_totals) == len(works) else None
        downloaded = sum(w["downloaded_files"] for w in works)
        missing_values = [w["missing_file_count"] for w in works if w.get("missing_file_count") is not None]
        missing = sum(missing_values) if len(missing_values) == len(works) else None
        units = {w.get("count_unit") or "files" for w in works}
        count_unit = units.pop() if len(units) == 1 else "items"
        if total:
            percent = round(downloaded * 100 / total)
            if all(w.get("percent") == 100 for w in works):
                percent = 100
            elif status == "running" and percent >= 100:
                percent = 99
        elif status == "done":
            percent = 100
        else:
            percent = None
    else:
        summary = library_summary()
        total = summary.get("library_works") or 0
        downloaded = total
        missing = summary.get("missing_subtitle_count") or 0
        count_unit = "works"
        percent = 100 if status == "done" else None
    return {
        "percent": percent,
        "downloaded_files": downloaded,
        "expected_files": total,
        "count_unit": count_unit,
        "missing_count": missing,
        "works": works,
        "updated_at": now_ms(),
    }


def action_snapshot(action_id: str) -> dict | None:
    with actions_lock:
        record = actions.get(action_id)
        if not record:
            return None
        record["progress"] = action_progress(record)
        return dict(record)


def action_list() -> list[dict]:
    with actions_lock:
        items = list(actions.values())[-25:]
        for record in items:
            record["progress"] = action_progress(record)
        return [dict(record) for record in reversed(items)]


def library_summary() -> dict:
    library_dirs = []
    missing_subs = []
    total_audio = 0
    total_subs = 0
    if LIBRARY_ROOT.is_dir():
        for p in sorted(LIBRARY_ROOT.iterdir()):
            if not p.is_dir() or not RJ_RE.match(p.name):
                continue
            has_audio = False
            has_sub = False
            for f in p.rglob("*"):
                if not f.is_file():
                    continue
                suffix = f.suffix.lower()
                if suffix in AUDIO_EXTS:
                    has_audio = True
                    total_audio += 1
                if suffix in SUB_EXTS:
                    has_sub = True
                    total_subs += 1
            library_dirs.append(p.name)
            if has_audio and not has_sub:
                missing_subs.append(p.name)

    db_works = None
    db_files = None
    conn = db_connect()
    if conn:
        try:
            db_works = conn.execute("SELECT COUNT(*) FROM works").fetchone()[0]
            db_files = conn.execute("SELECT COUNT(*) FROM files WHERE is_folder = 0").fetchone()[0]
        finally:
            conn.close()

    covers = 0
    if NEOKIKOERU_COVERS.is_dir():
        covers = sum(1 for f in NEOKIKOERU_COVERS.rglob("*") if f.is_file())

    failed_sync = 0
    err_log = STATE_ROOT / ".asmroner-data" / "download_errors.log"
    if err_log.exists():
        try:
            failed_sync = sum(1 for line in err_log.read_text(errors="ignore").splitlines() if line.strip())
        except OSError:
            failed_sync = -1

    return {
        "library_root": str(LIBRARY_ROOT),
        "library_mounted": LIBRARY_ROOT.is_dir(),
        "library_works": len(library_dirs),
        "db_works": db_works,
        "db_files": db_files,
        "covers": covers,
        "audio_files": total_audio,
        "subtitle_files": total_subs,
        "missing_subtitle_count": len(missing_subs),
        "missing_subtitles": missing_subs,
        "asmroner_failed_records": failed_sync,
    }


def health() -> dict:
    viewer = run_capture([str(ASMR_VIEW), "status"], timeout=10) if ASMR_VIEW.exists() else {"ok": False, "output": "asmr-view missing"}
    summary = library_summary()
    services = {
        "ASMR viewer": http_status("http://127.0.0.1:8890/api/health"),
        "ASMR storage": {
            "ok": bool(summary["library_mounted"]),
            "status": str(LIBRARY_ROOT),
        },
        "NeoKikoeru DB": {
            "ok": summary["db_works"] is not None,
            "status": f"{summary['db_works'] or 0} works",
        },
    }
    ok = all(v["ok"] for v in services.values())
    return {"ok": ok, "services": services, "viewer_status": viewer, "summary": summary}


def work_info(rj_raw: str) -> dict:
    rj = rj_arg(rj_raw)
    folder = LIBRARY_ROOT / rj
    out = {
        "rj": rj,
        "folder": str(folder),
        "folder_exists": folder.is_dir(),
        "audio_files": 0,
        "subtitle_files": 0,
        "image_files": 0,
        "db_work": None,
        "db_files": [],
    }
    if folder.is_dir():
        for f in folder.rglob("*"):
            if not f.is_file():
                continue
            suffix = f.suffix.lower()
            if suffix in AUDIO_EXTS:
                out["audio_files"] += 1
            elif suffix in SUB_EXTS:
                out["subtitle_files"] += 1
            elif suffix in {".jpg", ".jpeg", ".png", ".webp", ".gif"}:
                out["image_files"] += 1

    conn = db_connect()
    if conn:
        try:
            row = conn.execute("SELECT id, name, rating, rating_count, sales, price, age_category FROM works WHERE id = ?", (rj,)).fetchone()
            if row:
                out["db_work"] = dict(row)
            rows = conn.execute(
                "SELECT id, name, path, size, duration, is_folder FROM files WHERE work_id = ? ORDER BY is_folder DESC, path",
                (rj,),
            ).fetchall()
            out["db_files"] = [dict(x) for x in rows]
        finally:
            conn.close()
    return out


