<script>
let active = new Set();
const protectedActions = new Set(['download', 'fill']);
const adminAuthKey = 'asmrAdminBasicAuth';
async function api(path, opts={}) {
 const r = await fetch(path, opts);
 const j = await r.json();
 if (!r.ok) {
  const err = new Error(j.error || r.statusText);
  err.status = r.status;
  throw err;
 }
 return j;
}
function getAdminAuth(){ return sessionStorage.getItem(adminAuthKey) || ''; }
function setAdminAuth(user, pass){ sessionStorage.setItem(adminAuthKey, 'Basic '+btoa(`${user}:${pass}`)); updateAdminAuthStatus(); }
function updateAdminAuthStatus(){
 const el = document.getElementById('admin-auth-status');
 if(el) el.textContent = getAdminAuth() ? 'saved for session' : 'not saved';
}
function saveAdminAuth(){
 const user = document.getElementById('admin-user')?.value || 'admin';
 const pass = document.getElementById('admin-pass')?.value || '';
 if(!pass){ alert('Enter the admin password first.'); return false; }
 setAdminAuth(user, pass);
 return true;
}
function clearAdminAuth(){
 sessionStorage.removeItem(adminAuthKey);
 const pass = document.getElementById('admin-pass');
 if(pass) pass.value = '';
 updateAdminAuthStatus();
}
function requestAdminAuth(){
 return new Promise(resolve => {
  const existing = document.getElementById('admin-auth-modal');
  if(existing) existing.remove();
  const modal = document.createElement('div');
  modal.id = 'admin-auth-modal';
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.55);display:grid;place-items:center;z-index:20;';
  modal.innerHTML = `<form style="width:min(360px,calc(100vw - 32px));background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:16px;box-shadow:0 20px 60px rgba(0,0,0,.35)">
   <h2>Admin credentials</h2>
   <div class="row"><input name="user" autocomplete="username" placeholder="Username" value="admin" style="width:100%"></div>
   <div class="row"><input name="pass" autocomplete="current-password" placeholder="Password" type="password" style="width:100%"></div>
   <div class="row"><button type="submit">Continue</button><button type="button" data-cancel>Cancel</button></div>
  </form>`;
  document.body.appendChild(modal);
  const form = modal.querySelector('form');
  const pass = modal.querySelector('input[name=pass]');
  pass.focus();
  modal.querySelector('[data-cancel]').onclick = () => { modal.remove(); resolve(false); };
  form.onsubmit = e => {
   e.preventDefault();
   setAdminAuth(form.user.value || 'admin', form.pass.value || '');
   modal.remove();
   resolve(true);
  };
 });
}
function esc(s){return String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
function stat(label, value, cls=''){return `<div class="stat"><div class="label">${esc(label)}</div><div class="value ${cls}">${esc(value)}</div></div>`}
async function refresh(){
  const h = await api('/api/health');
  document.getElementById('stamp').textContent = new Date().toLocaleString();
  document.getElementById('health').innerHTML = Object.entries(h.services).map(([k,v]) =>
    `<div>${esc(k)}: <span class="${v.ok?'ok':'bad'}">${v.ok?'OK':'FAIL'}</span> ${esc(v.status||v.error||'')}</div>`).join('') +
    `<pre>${esc(h.viewer_status.output || h.viewer_status.error || '')}</pre>`;
  const s = h.summary;
  document.getElementById('summary').innerHTML = `<div class="grid">`+
    stat('Library works', s.library_works) + stat('DB works', s.db_works ?? '-') +
    stat('Covers', s.covers) + stat('Missing subs', s.missing_subtitle_count, s.missing_subtitle_count ? 'bad' : 'ok') +
    stat('Audio files', s.audio_files) + stat('Subtitle files', s.subtitle_files) + `</div>`+
    `<p class="label">${esc(s.library_root)}</p>`;
  document.getElementById('missing').innerHTML = s.missing_subtitles.length
    ? `<pre>${esc(s.missing_subtitles.join('\n'))}</pre>` : '<span class="ok">No missing subtitles</span>';
}
async function lookup(){
  const rj = document.getElementById('rj').value.trim();
  const w = await api('/api/work/'+encodeURIComponent(rj));
  document.getElementById('work').innerHTML = `<div class="grid">`+
    stat('Folder', w.folder_exists?'yes':'no', w.folder_exists?'ok':'bad')+
    stat('DB row', w.db_work?'yes':'no', w.db_work?'ok':'bad')+
    stat('Audio', w.audio_files)+stat('Subs', w.subtitle_files)+`</div>`+
    `<p>${esc(w.db_work?.name || '')}</p>`+
    `<pre>${esc(w.db_files.slice(0,80).map(f => (f.is_folder?'[dir] ':'      ')+f.path).join('\n'))}</pre>`;
}
async function action(name){
  const needsRj = !['reindex','fix-covers'].includes(name);
  const body = needsRj ? {rj: document.getElementById('rj').value.trim()} : (name === 'fix-covers' ? {rj: document.getElementById('rj').value.trim()} : {});
 const headers = {'Content-Type':'application/json'};
 if(protectedActions.has(name) && !getAdminAuth()){
  const pass = document.getElementById('admin-pass')?.value || '';
  if(pass) saveAdminAuth();
 }
 if(protectedActions.has(name) && getAdminAuth()) headers.Authorization = getAdminAuth();
 let rec;
 try {
  rec = await api('/api/actions/'+name, {method:'POST', headers, body:JSON.stringify(body)});
 } catch(e) {
  if(e.status === 401 && protectedActions.has(name) && await requestAdminAuth()) {
   headers.Authorization = getAdminAuth();
   rec = await api('/api/actions/'+name, {method:'POST', headers, body:JSON.stringify(body)});
  } else {
   throw e;
  }
 }
 active.add(rec.id);
 renderAction(rec);
 poll();
}
updateAdminAuthStatus();
function renderProgress(p){
 if(!p) return '';
 const pctKnown = p.percent !== null && p.percent !== undefined;
 const pct = pctKnown ? Math.max(0, Math.min(100, Number(p.percent || 0))) : 0;
 const pctLabel = pctKnown ? `${pct}%` : 'working';
 const missingLabel = p.missing_count ?? '?';
 const unit = p.count_unit || 'files';
 let html = `<div class="bar"><i style="width:${pct}%"></i></div>`+
 `<div class="progress-meta"><span>${pctLabel}</span><span>${esc(p.downloaded_files ?? 0)} / ${esc(p.expected_files ?? '?')} ${esc(unit)}</span><span>${esc(missingLabel)} missing</span></div>`;
 if((p.works||[]).length){
 html += (p.works||[]).map(w => {
 const wpKnown = w.percent !== null && w.percent !== undefined;
 const wp = wpKnown ? Math.max(0, Math.min(100, Number(w.percent || 0))) : 0;
 const wpLabel = wpKnown ? `${wp}%` : 'working';
 const source = w.expected_source ? ` · total from ${esc(w.expected_source)}` : '';
 const wunit = w.count_unit || 'files';
 const missing = (w.missing_files||[]).length
 ? `<details class="missing"><summary>${esc(w.missing_file_count)} missing file(s)</summary><pre>${esc((w.missing_files||[]).join('\n'))}</pre></details>`
 : '';
 return `<div class="stat"><strong>${esc(w.rj)}</strong> ${esc(w.title||'')}`+
 `<div class="bar"><i style="width:${wp}%"></i></div>`+
 `<div class="progress-meta"><span>${wpLabel}</span><span>${esc(w.downloaded_files)} / ${esc(w.expected_files ?? '?')} ${esc(wunit)}</span><span>${esc(w.audio_files)} audio · ${esc(w.subtitle_files)} subs</span></div>`+
 `<div class="label">final ${esc(w.final_files)} · staging ${esc(w.stage_files)} · folder ${w.folder_exists?'yes':'no'} · DB ${w.db_work?'yes':'no'}${source}</div>`+
 missing + `</div>`;
 }).join('');
 }
 return html;
}
function renderAction(a){
 let el = document.getElementById('act-'+a.id);
 if(!el){ el = document.createElement('div'); el.id='act-'+a.id; document.getElementById('actions').prepend(el); }
 el.innerHTML = `<h3>${esc(a.name)} <span class="${a.status==='done'?'ok':a.status==='failed'?'bad':''}">${esc(a.status)}</span></h3>`+
 `<div class="label">${esc((a.argv||[]).join(' '))}</div>`+
 renderProgress(a.progress)+
 `<pre>${esc(a.output || a.error || '')}</pre>`;
}
async function poll(){
  for(const id of Array.from(active)){
    const a = await api('/api/actions/'+id);
    renderAction(a);
    if(a.status !== 'running') active.delete(id);
  }
  if(active.size) setTimeout(poll, 1500);
}
refresh().catch(e => document.body.insertAdjacentHTML('beforeend','<pre>'+esc(e.message)+'</pre>'));
</script>
</body>
</html>
"""


class Handler(BaseHTTPRequestHandler):
    server_version = "asmr-dashboard/1.0"

    def log_message(self, fmt: str, *args) -> None:
        print("%s - %s" % (self.address_string(), fmt % args), flush=True)

    def send_json(self, data, status=HTTPStatus.OK) -> None:
        body = json.dumps(data, ensure_ascii=False, indent=2).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_html(self, body: str) -> None:
        raw = body.encode("utf-8")
        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(raw)))
        self.end_headers()
        self.wfile.write(raw)

    def read_json(self) -> dict:
        n = int(self.headers.get("Content-Length", "0") or 0)
        if n <= 0:
            return {}
        return json.loads(self.rfile.read(n).decode("utf-8"))

    def do_GET(self) -> None:
        try:
            path = urllib.parse.urlparse(self.path).path
            if path in ("/", "/index.html"):
                return self.send_html(INDEX_HTML)
            if path == "/api/health":
                return self.send_json(health())
            if path == "/api/library/summary":
                return self.send_json(library_summary())
            if path == "/api/subtitles/missing":
                return self.send_json({"items": library_summary()["missing_subtitles"]})
            if path.startswith("/api/work/"):
                rj = urllib.parse.unquote(path.rsplit("/", 1)[-1])
                return self.send_json(work_info(rj))
            if path.startswith("/api/actions/"):
                action_id = path.rsplit("/", 1)[-1]
                rec = action_snapshot(action_id)
                if not rec:
                    return self.send_json({"error": "action not found"}, HTTPStatus.NOT_FOUND)
                return self.send_json(rec)
            return self.send_json({"error": "not found"}, HTTPStatus.NOT_FOUND)
        except Exception as e:
            return self.send_json({"error": str(e)}, HTTPStatus.INTERNAL_SERVER_ERROR)

    def do_POST(self) -> None:
        try:
            path = urllib.parse.urlparse(self.path).path
            if not path.startswith("/api/actions/"):
                return self.send_json({"error": "not found"}, HTTPStatus.NOT_FOUND)
            name = path.rsplit("/", 1)[-1]
            body = self.read_json()
            if name == "fix-covers":
                sample_rj = rj_arg(body.get("rj", "RJ01580504") or "RJ01580504")
                rec = queue_action("fix-covers", [str(STATE_ROOT / "bin" / "asmr-fix-covers-workflow"), sample_rj], timeout=1800)
            elif name == "reindex":
                rec = queue_action("reindex", [str(ASMR_LIBRARY), "reindex"], timeout=1800)
            else:
                rj = rj_arg(body.get("rj", ""))
                mapping = {
                    "download": [str(ASMR_LIBRARY), "download", rj],
                    "retry": [str(ASMR_LIBRARY), "retry", rj],
                    "fill": [str(ASMR_LIBRARY), "fill", rj],
                    "fix-content": [str(STATE_ROOT / "bin" / "asmr-fix-content-workflow"), rj],
                    "subs-dry-run": [str(ASMR_LIBRARY), "subs", "fetch", rj, "--dry-run"],
                    "subs-fetch": [str(ASMR_LIBRARY), "subs", "fetch", rj],
                }
                if name not in mapping:
                    return self.send_json({"error": "unknown action"}, HTTPStatus.NOT_FOUND)
                rec = queue_action(name, mapping[name], timeout=1800)
            return self.send_json(rec, HTTPStatus.ACCEPTED)
        except Exception as e:
            return self.send_json({"error": str(e)}, HTTPStatus.BAD_REQUEST)


def main() -> None:
    ap = argparse.ArgumentParser(description="ASMR library operator dashboard")
    ap.add_argument("--host", default=os.environ.get("ASMR_DASHBOARD_HOST", "127.0.0.1"))
    ap.add_argument("--port", type=int, default=int(os.environ.get("ASMR_DASHBOARD_PORT", "8891")))
    args = ap.parse_args()
    if not ASMR_LIBRARY.exists():
        raise SystemExit(f"asmr-library not found: {ASMR_LIBRARY}")
    httpd = ThreadingHTTPServer((args.host, args.port), Handler)
    print(f"ASMR dashboard listening on http://{args.host}:{args.port}", flush=True)
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nASMR dashboard stopped", flush=True)


if __name__ == "__main__":
    main()
